          "text": [
            "{} | 0 1 2 \n",
            "---\n",
            "0 | 0 1 2 \n",
            "1 | 1 2 0 \n",
            "2 | 2 0 1 \n"
          ]
        }
      ],
      "source": [
        "# Rudranarayan Jena\n",
        "S = [0, 1, 2]\n",
        "print(\"{} |\", end=\" \")\n",
        "for b in S:\n",
        "    print(b, end=\" \")\n",
        "print(\"\\n---\")\n",
        "for a in S:\n",
        "    print(a, \"|\", end=\" \")\n",
        "    for b in S:\n",
        "        result = (a + b) % 3\n",
        "        print(result, end=\" \")\n",
        "    print()"
      ]
    },
